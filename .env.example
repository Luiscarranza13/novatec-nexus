# Supabase Setup - Variables de Entorno
# Copiar este archivo como .env.local o .env

# URL del proyecto Supabase (ej: https://abcd1234.supabase.co)
SUPABASE_URL=""

# Service Role Key de Supabase
# ⚠️ MANTENER SECRETA - tiene acceso completo a la base de datos
# Se obtiene desde: Supabase Dashboard → Settings → API → Service Role Key
SUPABASE_SERVICE_ROLE_KEY=""

# Opcional: Anon Key (solo lectura para clientes)
# Se obtiene desde: Supabase Dashboard → Settings → API → anon key
SUPABASE_ANON_KEY=""

# Opcional: URL pública (para frontend)
VITE_SUPABASE_URL=""

# Opcional: Anon Key pública (para frontend)
VITE_SUPABASE_PUBLISHABLE_KEY=""

# =============================================
# ⚠️ IMPORTANTE: Seguridad
# =============================================
# 1. Nunca commit el archivo .env con las keys reales
# 2. El Service Role Key tiene acceso completo a la DB
# 3. Mantenerlo solo en el entorno de desarrollo/deploy
# 4. Para producción, usar variables del sistema del host
# =============================================
